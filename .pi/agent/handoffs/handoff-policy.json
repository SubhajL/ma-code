{
  "notes": [
    "Machine-readable HARNESS-022 handoff policy for the repo-local Pi harness.",
    "This policy preserves HARNESS-021 task packet scope and evidence expectations.",
    "It is intentionally narrower than queue-driven dispatch or long-running autonomy runtime."
  ],
  "defaults": {
    "preserve_packet_scope": true,
    "preserve_evidence_expectations": true,
    "preserve_escalation_instructions": true,
    "default_none_token": "none"
  },
  "handoff_rules": {
    "build_to_worker": {
      "from_roles": ["build_lead"],
      "to_roles": ["frontend_worker", "backend_worker", "infra_worker"],
      "required_headers": [
        "## Worker Assignment",
        "## Scope Boundaries",
        "## Discovery Summary",
        "## Acceptance Criteria",
        "## Evidence Expectations",
        "## Wiring Checks",
        "## Escalations"
      ],
      "required_detail_fields": [],
      "required_packet_fields": [
        "goal",
        "scope_boundaries",
        "discovery_summary",
        "evidence_expectations",
        "wiring_checks",
        "expected_proof"
      ]
    },
    "worker_to_quality": {
      "from_roles": ["research_worker", "frontend_worker", "backend_worker", "infra_worker", "docs_worker"],
      "to_roles": ["quality_lead"],
      "required_headers": [
        "## Work Summary",
        "## Discovery Summary",
        "## Scope Boundaries",
        "## Acceptance Coverage",
        "## Evidence",
        "## Evidence Expectations",
        "## Validation Commands",
        "## Wiring Checks",
        "## Wiring Verification",
        "## Known Gaps",
        "## Blockers"
      ],
      "required_detail_fields": [
        "changed_files",
        "acceptance_coverage",
        "evidence",
        "commands_run",
        "wiring_verification"
      ],
      "required_packet_fields": [
        "discovery_summary",
        "scope_boundaries",
        "evidence_expectations",
        "expected_proof"
      ]
    },
    "quality_to_reviewer": {
      "from_roles": ["quality_lead"],
      "to_roles": ["reviewer_worker"],
      "required_headers": [
        "## Review Scope",
        "## Claimed Completion Status",
        "## Scope Boundaries",
        "## Files To Inspect",
        "## Risks To Challenge",
        "## Questions For Reviewer"
      ],
      "required_detail_fields": [
        "review_scope",
        "claimed_completion_status",
        "files_to_inspect",
        "risks_to_challenge",
        "questions_for_reviewer"
      ],
      "required_packet_fields": [
        "scope_boundaries",
        "discovery_summary"
      ]
    },
    "quality_to_validator": {
      "from_roles": ["quality_lead"],
      "to_roles": ["validator_worker"],
      "required_headers": [
        "## Validation Scope",
        "## Scope Boundaries",
        "## Acceptance Criteria",
        "## Expected Proof",
        "## Validation Questions",
        "## Wiring Checks",
        "## Risks"
      ],
      "required_detail_fields": [
        "validation_scope",
        "expected_proof",
        "validation_questions",
        "known_gaps"
      ],
      "required_packet_fields": [
        "scope_boundaries",
        "expected_proof"
      ]
    },
    "recovery_to_orchestrator_or_lead": {
      "from_roles": ["recovery_worker"],
      "to_roles": ["orchestrator", "planning_lead", "build_lead", "quality_lead"],
      "required_headers": [
        "## Failure Type",
        "## Likely Causes",
        "## Recovery Options",
        "## Recommended Action",
        "## Migration Path Note",
        "## Stop Threshold"
      ],
      "required_detail_fields": [
        "failure_type",
        "likely_causes",
        "recovery_options",
        "recommended_action",
        "migration_path_note",
        "stop_threshold"
      ],
      "required_packet_fields": [
        "scope_boundaries"
      ]
    }
  }
}
