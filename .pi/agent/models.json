{
  "notes": [
    "Internal harness routing map for this repo.",
    "This file is not Pi's provider registry models.json.",
    "Exact provider and model IDs below were verified against `pi --list-models`.",
    "HARNESS-017 executable routing reads this file as the machine-readable routing policy source."
