  "routing_policy": {
    "critical_roles": [
      "orchestrator",
      "planning_lead",
      "quality_lead",
      "infra_worker",
      "reviewer_worker",
      "validator_worker",
      "recovery_worker"
    ],
    "override_reasons": {
      "default": {
        "allowed_roles": [
          "*"
        ],
        "blocked_roles": [],
        "may_use_fallback_order": true,
        "may_use_budget_overrides": false,
        "prefer_stronger_override": false
      },
      "task_simpler": {
        "allowed_roles": [
          "research_worker",
          "docs_worker",
          "frontend_worker",
          "backend_worker"
        ],
        "blocked_roles": [
          "orchestrator",
          "planning_lead",
          "build_lead",
          "quality_lead",
          "infra_worker",
          "reviewer_worker",
          "validator_worker",
          "recovery_worker"
        ],
        "may_use_fallback_order": false,
        "may_use_budget_overrides": true,
        "prefer_stronger_override": false
      },
      "task_harder": {
        "allowed_roles": [
          "*"
        ],
        "blocked_roles": [],
        "may_use_fallback_order": true,
        "may_use_budget_overrides": false,
        "prefer_stronger_override": true
      },
      "provider_failure": {
        "allowed_roles": [
          "*"
        ],
        "blocked_roles": [],
        "may_use_fallback_order": true,
        "may_use_budget_overrides": false,
        "prefer_stronger_override": false
      },
      "budget_pressure": {
        "allowed_roles": [
          "research_worker",
          "docs_worker",
          "frontend_worker",
          "backend_worker"
        ],
        "blocked_roles": [
          "orchestrator",
          "planning_lead",
          "build_lead",
          "quality_lead",
          "infra_worker",
          "reviewer_worker",
          "validator_worker",
          "recovery_worker"
        ],
        "may_use_fallback_order": false,
        "may_use_budget_overrides": true,
        "prefer_stronger_override": false
      },
      "recovery_recommendation": {
        "allowed_roles": [
          "*"
        ],
        "blocked_roles": [],
        "may_use_fallback_order": true,
        "may_use_budget_overrides": false,
        "prefer_stronger_override": false
      },
      "human_override": {
        "allowed_roles": [
          "*"
        ],
        "blocked_roles": [],
        "may_use_fallback_order": true,
        "may_use_budget_overrides": true,
        "prefer_stronger_override": false
      }
    },
    "budget_modes": {
      "default": {
        "allow_budget_overrides": false,
        "prefer_stronger_override": false
      },
      "balanced": {
        "allow_budget_overrides": false,
        "prefer_stronger_override": false
      },
