{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskState",
  "type": "object",
  "required": [
    "version",
    "activeTaskId",
    "tasks"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "activeTaskId": {
      "type": [
        "string",
        "null"
      ]
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "owner",
          "status",
          "taskClass",
          "acceptance",
          "evidence",
          "dependencies",
          "retryCount",
          "validation",
          "notes",
          "timestamps"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "owner": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "in_progress",
              "review",
              "blocked",
              "done",
              "failed"
            ]
          },
          "taskClass": {
            "type": "string",
            "enum": [
              "research",
              "docs",
              "implementation",
              "runtime_safety"
            ]
          },
          "acceptance": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "retryCount": {
            "type": "integer",
            "minimum": 0
          },
          "validation": {
            "type": "object",
            "required": [
              "tier",
              "decision",
              "source",
              "checklist",
              "approvalRef",
              "updatedAt"
            ],
            "properties": {
              "tier": {
                "type": "string",
                "enum": [
                  "lightweight",
                  "standard",
                  "strict"
                ]
              },
              "decision": {
                "type": "string",
                "enum": [
                  "pending",
                  "pass",
                  "fail",
                  "blocked",
                  "overridden"
                ]
              },
              "source": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  "review",
                  "validator",
                  "override",
                  null
                ]
              },
              "checklist": {
                "type": [
                  "object",
                  "null"
                ],
                "required": [
                  "acceptance",
                  "tests",
                  "diff_review",
                  "evidence"
                ],
                "properties": {
                  "acceptance": {
                    "type": "string",
                    "enum": [
                      "met",
                      "partial",
                      "not_met",
                      "not_applicable"
                    ]
                  },
                  "tests": {
                    "type": "string",
                    "enum": [
                      "met",
                      "partial",
                      "not_met",
                      "not_applicable"
                    ]
                  },
                  "diff_review": {
                    "type": "string",
                    "enum": [
                      "met",
                      "partial",
                      "not_met",
                      "not_applicable"
                    ]
                  },
                  "evidence": {
                    "type": "string",
                    "enum": [
                      "met",
                      "partial",
                      "not_met",
                      "not_applicable"
                    ]
                  }
                }
              },
              "approvalRef": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "updatedAt": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "timestamps": {
            "type": "object",
            "required": [
              "createdAt",
              "updatedAt"
            ],
            "properties": {
              "createdAt": {
                "type": "string"
              },
              "updatedAt": {
                "type": "string"
              },
              "startedAt": {
                "type": "string"
              },
              "completedAt": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
