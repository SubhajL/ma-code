{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JobQueueState",
  "type": "object",
  "required": [
    "version",
    "paused",
    "activeJobId",
    "jobs"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "paused": {
      "type": "boolean"
    },
    "activeJobId": {
      "type": [
        "string",
        "null"
      ]
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "goal",
          "priority",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "scope": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "running",
              "blocked",
              "done",
              "failed"
            ]
          },
          "team": {
            "type": "string",
            "enum": [
              "planning",
              "build",
              "quality",
              "recovery"
            ]
          },
          "budget": {
            "type": "object",
            "properties": {
              "maxRetries": {
                "type": "integer",
                "minimum": 0
              },
              "maxRuntimeMinutes": {
                "type": "integer",
                "minimum": 1
              },
              "maxCostUsd": {
                "type": "number",
                "minimum": 0
              },
              "maxFilesChanged": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          },
          "stop_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
