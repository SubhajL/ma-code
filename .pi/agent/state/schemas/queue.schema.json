{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JobQueueState",
  "type": "object",
  "required": [
    "version",
    "paused",
    "activeJobId",
    "jobs"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "paused": {
      "type": "boolean"
    },
    "activeJobId": {
      "type": [
        "string",
        "null"
      ]
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "goal",
          "priority",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "scope": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "running",
              "blocked",
              "done",
              "failed"
            ]
          },
          "team": {
            "type": "string",
            "enum": [
              "planning",
              "build",
              "quality",
              "recovery"
            ]
          },
          "budget": {
            "type": "object",
            "properties": {
              "maxRetries": {
                "type": "integer",
                "minimum": 0
              },
              "maxRuntimeMinutes": {
                "type": "integer",
                "minimum": 1
              },
              "maxCostUsd": {
                "type": "number",
                "minimum": 0
              },
              "maxFilesChanged": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          },
          "stop_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptanceCriteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "taskClass": {
            "type": "string",
            "enum": [
              "research",
              "docs",
              "implementation",
              "runtime_safety"
            ]
          },
          "workType": {
            "type": "string",
            "enum": [
              "implementation",
              "docs_only",
              "research_only",
              "review_only",
              "mixed"
            ]
          },
          "domains": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "frontend",
                "backend",
                "infra",
                "docs",
                "research"
              ]
            }
          },
          "allowedPaths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "assignedRole": {
            "type": "string",
            "enum": [
              "orchestrator",
              "planning_lead",
              "build_lead",
              "quality_lead",
              "research_worker",
              "frontend_worker",
              "backend_worker",
              "infra_worker",
              "reviewer_worker",
              "validator_worker",
              "docs_worker",
              "recovery_worker"
            ]
          },
          "routeReason": {
            "type": "string",
            "enum": [
              "default",
              "task_simpler",
              "task_harder",
              "provider_failure",
              "budget_pressure",
              "recovery_recommendation",
              "human_override"
            ]
          },
          "budgetMode": {
            "type": "string",
            "enum": [
              "default",
              "balanced",
              "conserve",
              "high"
            ]
          },
          "modelOverride": {
            "type": "string"
          },
          "linkedTaskId": {
            "type": [
              "string",
              "null"
            ]
          },
          "packetId": {
            "type": [
              "string",
              "null"
            ]
          },
          "selectedModelId": {
            "type": [
              "string",
              "null"
            ]
          },
          "initialHandoffId": {
            "type": [
              "string",
              "null"
            ]
          },
          "lastRecoveryAction": {
            "type": "string",
            "enum": [
              "retry_same_lane",
              "retry_stronger_model",
              "switch_provider",
              "rollback",
              "stop",
              "escalate"
            ]
          },
          "lastRecoveryReason": {
            "type": "string"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "startedAt": {
            "type": "string"
          },
          "finishedAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
